APP_MODE=EXPERIMENT

# Transfer-learning sample weights (simulated vs real-world)
SIM_WEIGHT=0.2
REAL_WEIGHT=1.0
MODELS_TO_USE=linear,random_forest,xgboost

# Experiment and tournament cadence
NUM_SIM_RUNS=100
EVAL_INTERVAL=10
PRODUCTION_RUNS=10
RANDOM_SEED=42

# Physics baseline coefficients and voltage slowdown
PHYSICS_TILE_TIME=1.2
PHYSICS_TURN_TIME=1.8
PHYSICS_NOMINAL_VOLTAGE=12.0
BATTERY_DECAY_EXPONENT=1.2
# Runtime noise for simulated and real runs
TIME_NOISE_STD=0.4
TIME_NOISE_STD_REAL=0.8

# Input ranges used by MockPhysicsEnv
TOTAL_TILES_MIN=20
TOTAL_TILES_MAX=60
NUM_CORNERS_MIN=4
NUM_CORNERS_MAX=8
START_BATTERY_MIN=10.0
START_BATTERY_MAX=12.0
CALIBRATIONS_MIN=1
CALIBRATIONS_MAX=10
# Endpoint bounds and real-world scaling
ENDPOINT_ERROR_ABS_MAX_CM=50.0
ENDPOINT_DEVIATION_ABS_MAX_DEG=15.0
REAL_WORLD_ERROR_MULTIPLIER=1.15

# Tournament hyperparameter search grids
LR_FIT_INTERCEPT_OPTIONS=true,false
RF_N_ESTIMATORS_OPTIONS=80,120
RF_MAX_DEPTH_OPTIONS=4,6
XGB_MAX_DEPTH_OPTIONS=3,5
XGB_LEARNING_RATE_OPTIONS=0.05,0.1
XGB_N_ESTIMATORS_OPTIONS=60,100

# Output artifact paths
RUN_HISTORY_PATH=run_history.csv
SYSTEM_LOG_PATH=system.log
CHAMPION_MODEL_PATH=champion_model.pkl
